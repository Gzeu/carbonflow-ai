# ─── GitHub App ───────────────────────────────────────────────────────────────
GITHUB_APP_ID=1989339
WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ─── Carbon Thresholds ────────────────────────────────────────────────────────
CARBON_THRESHOLD_YELLOW=0.5
CARBON_THRESHOLD_RED=1.0

# ─── Supabase (persistent storage) ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── Slack Notifications ──────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# NOTIFY_ON_GREEN=1       # uncomment to also notify on green commits

# ─── Email Notifications (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@carbonflow-ai.vercel.app
EMAIL_TO=you@example.com,team@example.com
EMAIL_NOTIFY_LEVEL=red       # red | yellow | all
EMAIL_SUBJECT_PREFIX=[CarbonFlow AI]

# ─── MultiversX ESDT Carbon Credits ──────────────────────────────────────────
MULTIVERSX_API_URL=https://devnet-api.multiversx.com
MULTIVERSX_TOKEN_ID=CCR-a1b2c3
MULTIVERSX_SIGNER_ADDRESS=erd1...
MULTIVERSX_MINT_AMOUNT=1000000000000000000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=3600000    # 1 hour sliding window
RATE_LIMIT_MAX_EVENTS=100       # max webhook events per repo per window

# ─── API Security ─────────────────────────────────────────────────────────────
CARBONFLOW_API_KEY=your_internal_api_key_here

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
